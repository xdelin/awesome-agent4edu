{
  "name": "@neondatabase/mcp-server-neon",
  "version": "0.8.0",
  "description": "MCP server for interacting with Neon Management API and databases",
  "license": "MIT",
  "author": "Neon, Inc. (https://neon.com/)",
  "homepage": "https://github.com/neondatabase/mcp-server-neon/",
  "bugs": "https://github.com/neondatabase/mcp-server-neon/issues",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix . && prettier -w .",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier -w .",
    "fmt:check": "prettier --check .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "test": "vitest run",
    "test:unit": "vitest run --exclude \"**/*.integration.test.ts\" --exclude \"**/*.e2e.test.ts\"",
    "test:integration": "vitest run integration.test.ts",
    "test:e2e:mcp": "vitest run e2e.test.ts",
    "test:e2e:web": "playwright test",
    "test:watch": "vitest",
    "test:e2e": "bun run test:e2e:mcp && bun run test:e2e:web",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:e2e"
  },
  "dependencies": {
    "@keyv/postgres": "2.1.2",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@neondatabase/api-client": "2.5.0",
    "@neondatabase/serverless": "1.0.0",
    "@segment/analytics-node": "2.2.1",
    "@sentry/node": "9.19.0",
    "@vercel/functions": "^3.3.4",
    "axios": "^1.7.9",
    "he": "^1.2.0",
    "keyv": "5.3.2",
    "mcp-handler": "1.0.6",
    "next": "^16.1.1",
    "oauth2-server": "3.1.1",
    "openid-client": "6.3.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "winston": "3.17.0",
    "zod": "^3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/he": "^1.2.3",
    "@types/node": "^20",
    "@types/oauth2-server": "3.0.18",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.4",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "knip": "^5.83.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
